# ==================== 앱 ====================
APP_MODE=mock
AUTH_MODE=mock
APP_TIMEZONE=Asia/Seoul
SESSION_SECRET=change-me-to-random-secret
# 세션 정책: 마지막 활동 기준 idle(슬라이딩) + 로그인 기준 absolute(상한)
SESSION_IDLE_MINUTES=120
SESSION_ABSOLUTE_MINUTES=720
# 쿠키 옵션 (운영 HTTPS 에서는 SESSION_COOKIE_SECURE=true 권장)
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# ==================== DB / Redis ====================
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<RDS_HOST>:5432/bi_portal
DATABASE_SSL=disable
DATABASE_SCHEMA=bip
REDIS_URL=redis://redis:6379/0

# ==================== Azure AD / Power BI ====================
AZURE_TENANT_ID=<AZURE_TENANT_ID>
AZURE_CLIENT_ID=<AZURE_CLIENT_ID>
AZURE_CLIENT_SECRET=<AZURE_CLIENT_SECRET>
POWERBI_WORKSPACE_ID=<POWERBI_WORKSPACE_ID>
POWERBI_API_BASE_URL=https://api.powerbi.com/v1.0/myorg
POWERBI_VERIFY_SSL=false

# ==================== 인사정보 DB 인증 ====================
HR_PWD_HASH_ROUNDS=3

# ==================== SMTP ====================
SMTP_HOST=<SMTP_HOST>
SMTP_PORT=587
SMTP_FROM=bip@example.com
SMTP_USE_AUTH=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=false

# ==================== 작업 주기 ====================
COLLECT_INTERVAL_MINUTES=5
EXPORT_POLL_INTERVAL_SEC=5
EXPORT_POLL_TIMEOUT_SEC=600
MAIL_RETRY_MAX=3

# ==================== 파일/보존 ====================
STORAGE_ROOT_PATH=/data/reportimage
STORAGE_BACKEND=local
SERVE_REPORTIMAGE_STATIC=false
IMAGE_RETENTION_DAYS=90
AUDIT_RETENTION_DAYS=365
UNUSED_REPORT_DAYS=90

# ==================== 프론트엔드 ====================
AUTO_REFRESH_INTERVAL_SEC=60
CORS_ALLOWED_ORIGINS=http://localhost:80
