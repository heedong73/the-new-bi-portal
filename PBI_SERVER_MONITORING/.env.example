# ============================================================
# Power BI Refresh Monitor - 환경 변수 예시 파일
# ------------------------------------------------------------
# 사용 방법:
#   1) 이 파일을 복사하여 .env 파일을 만든다.
#        cp .env.example .env   (Windows PowerShell: Copy-Item .env.example .env)
#   2) 아래 placeholder 값을 실제 환경 값으로 교체한다.
#   3) .env 파일은 절대 git에 커밋하지 않는다 (.gitignore 처리됨).
#
# 주의: 여기의 값은 모두 placeholder 이며 실제 시크릿이 아니다.
# ============================================================

# ----- Azure AD (Power BI 인증, Live_Mode 에서만 필요) -----
# Azure AD client credentials flow 용 자격 증명
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=your-client-secret-here

# ----- Power BI -----
# 모니터링 대상 Workspace(group) ID
POWERBI_WORKSPACE_ID=00000000-0000-0000-0000-000000000000
# Power BI REST API 베이스 URL (기본값 유지 권장)
POWERBI_API_BASE_URL=https://api.powerbi.com/v1.0/myorg

# ----- 데이터 저장소 -----
# postgres 컨테이너 초기화 값 (docker-compose.yml 에서 사용)
POSTGRES_USER=prm
POSTGRES_PASSWORD=prm
POSTGRES_DB=prm
# PostgreSQL 연결 문자열 (SQLAlchemy async / asyncpg).
#   compose 내부 서비스명(postgres) 기준이며 위 POSTGRES_* 값과 일치해야 한다.
DATABASE_URL=postgresql+asyncpg://prm:prm@postgres:5432/prm
# Redis 연결 문자열 (토큰 캐시 / 분산 락 / Celery broker)
REDIS_URL=redis://redis:6379/0

# ----- 애플리케이션 설정 -----
# 화면/저장 시각 변환 기준 타임존 (기본값 Asia/Seoul)
APP_TIMEZONE=Asia/Seoul
# 운영 모드: mock | live  (기본값 mock - 외부 Power BI API 미호출)
APP_MODE=mock
# Collector 수집 주기(분). 허용값 1 또는 5
COLLECT_INTERVAL_MINUTES=5
# Refresh history 응답 Redis 캐시 TTL(초)
CACHE_TTL_SECONDS=60
# Backend CORS 허용 Origin 목록 (콤마 구분)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ----- Frontend -----
# 자동 새로고침 토글 활성 시 재조회 간격(초)
AUTO_REFRESH_INTERVAL_SEC=60
# Frontend가 호출할 Backend API 베이스 URL (Vite 빌드 시 VITE_ 접두사 필요).
#   - 미설정 시 http://localhost:8000 으로 fallback (dev, CORS 허용됨)
#   - nginx /api 프록시 사용 시 빈 값으로 두어 상대경로(/api/...) 호출
VITE_API_BASE_URL=http://localhost:8000
