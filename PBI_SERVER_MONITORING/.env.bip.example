# ============================================================
# The New BI Portal (BIP) v1.0 - 환경 변수 예시 파일
# ------------------------------------------------------------
# 사용 방법:
#   1) 이 파일을 복사하여 .env 파일을 만든다.
#        macOS/Linux : cp .env.bip.example .env
#        PowerShell  : Copy-Item .env.bip.example .env
#   2) 아래 <PLACEHOLDER> 값을 실제 환경 값으로 교체한다.
#   3) .env 파일은 절대 git에 커밋하지 않는다 (.gitignore 처리됨).
#
# 환경 분리(D-23):
#   - 개발계(dev, 현재)는 .env.dev, 운영계(prod)는 .env.prod 로 동일 구조를 사용한다.
#   - 환경별 차이(DB/워크스페이스/Azure/SMTP/STORAGE 등)는 코드가 아니라 .env 로만 표현한다.
#   - 스키마는 Alembic 마이그레이션으로 환경 간 동일하게 재현한다(수동 DDL 금지).
#
# 보안 원칙(R38.2):
#   실제 RDS 호스트, SMTP 호스트, Power BI 워크스페이스 ID, Azure 자격 증명 등
#   환경별 실제 엔드포인트/식별자/시크릿은 이 예시 파일에 절대 기재하지 않는다.
#   아래 값은 모두 플레이스홀더이며 실제 시크릿이 아니다.
# ============================================================

# ----- 앱 -----
# 운영 모드: mock | live  (mock = 외부 Power BI/Azure 미호출, 화면/시연용)
APP_MODE=mock
# 인증 모드: hr-db | local-only | mock
#   hr-db      = 인사정보 뷰(scl_v_insa_*) 기반 사번/비밀번호 로그인(운영)
#   local-only = 비상 로컬 관리자만 허용(인사 DB 장애 시)
#   mock       = 개발용 mock 사용자 로그인(인사 DB 불필요)
AUTH_MODE=mock
# 화면/저장 시각 변환 기준 타임존
APP_TIMEZONE=Asia/Seoul
# 세션 서명/암호화용 시크릿 (충분히 긴 임의 문자열로 교체)
SESSION_SECRET=<SESSION_SECRET>
# 세션 만료(분). 기본 480분(8시간)
SESSION_TTL_MINUTES=480

# ----- 외부 DB / Redis -----
# 운영 DB: AWS RDS PostgreSQL (서울 리전 ap-northeast-2, DB명 bi_portal, SSL 필수)
# 현재 RDS는 개발계(dev). 운영계(prod)는 .env.prod 로 동일 구조 구축.
# 실제 호스트/식별자 값은 이 파일에 적지 않고 .env(gitignore)에만 보관한다.
DATABASE_URL=postgresql+asyncpg://<DB_USER>:<DB_PASSWORD>@<RDS_HOST>:5432/bi_portal
# RDS가 SSL 연결을 요구(평문 연결은 pg_hba 거부). asyncpg ssl=true 로 적용
DATABASE_SSL=require
# BIP 전용 스키마(인사 뷰 public 과 분리, D-17)
DATABASE_SCHEMA=bip
# Redis 연결 문자열 (cache / queue / lock / token cache 전용, 원장 저장 금지)
REDIS_URL=redis://redis:6379/0

# ----- Azure AD / Power BI -----
# Azure AD client credentials flow 용 자격 증명 (live 모드에서만 필요)
AZURE_TENANT_ID=<AZURE_TENANT_ID>
AZURE_CLIENT_ID=<AZURE_CLIENT_ID>
AZURE_CLIENT_SECRET=<AZURE_CLIENT_SECRET>
# 대상 Power BI 워크스페이스(group) ID
POWERBI_WORKSPACE_ID=<POWERBI_WORKSPACE_ID>
# Power BI REST API 베이스 URL (기본값 유지 권장)
POWERBI_API_BASE_URL=https://api.powerbi.com/v1.0/myorg
# Power BI/Azure 호출 시 TLS 인증서 검증 여부
POWERBI_VERIFY_SSL=true

# ----- 인사정보 DB 인증 (D-01) -----
# 인사 뷰는 운영 DB(bi_portal)에 동일 존재하며 읽기 전용으로만 참조한다.
# login_pwd 검증용 단순 SHA-256 반복 횟수 (salt 없음, 레거시 호환 목적)
HR_PWD_HASH_ROUNDS=3

# ----- SMTP (기존 업체와 동일: 미인증 발송) -----
# 실제 사내 메일 서버 호스트는 이 파일에 적지 않고 .env 에만 보관한다.
SMTP_HOST=<SMTP_HOST>
SMTP_PORT=587
SMTP_FROM=<SMTP_FROM>
# 인증/TLS 미사용이 기본. 사내 정책 변경 시 아래 값으로 인증/STARTTLS 활성화
SMTP_USE_AUTH=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=false

# ----- 작업 주기 -----
# Refresh History 수집 주기(분)
COLLECT_INTERVAL_MINUTES=5
# Export to File 상태 polling 간격(초) / 전체 timeout(초)
EXPORT_POLL_INTERVAL_SEC=5
EXPORT_POLL_TIMEOUT_SEC=600
# 메일 발송 실패 시 최대 재시도 횟수
MAIL_RETRY_MAX=3

# ----- Power BI Embedded 용량 자동 스케일 (D-21, v1.2 연기) -----
# v1.0 에서는 사용하지 않는다. 참고용 placeholder 이며 기본 비활성.
CAPACITY_AUTOSCALE_ENABLED=false
CAPACITY_PEAK_SKU=A2
CAPACITY_OFFPEAK_SKU=A1
CAPACITY_PEAK_START=03:00
CAPACITY_PEAK_END=08:00
CAPACITY_AZURE_RESOURCE_ID=

# ----- 파일 저장소 / 보존 (StorageService, D-09) -----
# 개발=Docker volume, 운영=NAS 마운트(경로 확정 시 값만 교체, 코드 변경 없음)
STORAGE_ROOT_PATH=/data/reportimage
# 저장소 백엔드: local | nas | s3(확장)
STORAGE_BACKEND=local
# nginx /reportimage/* 정적 서빙(권한 검증 우회) — 기본 off, 내부망 편의 시만 on
SERVE_REPORTIMAGE_STATIC=false
# 저장 이미지 보존 일수 / 감사 로그 보존 일수
IMAGE_RETENTION_DAYS=90
AUDIT_RETENTION_DAYS=365
# 미사용 리포트 판정 기준 일수(통계)
UNUSED_REPORT_DAYS=90

# ----- 프론트 -----
# 화면 자동 리렌더링(재조회) 기본 간격(초)
AUTO_REFRESH_INTERVAL_SEC=60
# Backend CORS 허용 Origin 목록 (콤마 구분, 내부망 도메인으로 교체)
CORS_ALLOWED_ORIGINS=https://bip.intra.example
